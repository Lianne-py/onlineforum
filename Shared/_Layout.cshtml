<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Forum</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
                    colors: {
                        surface: '#fafafa',
                        border: '#e5e7eb',
                        muted: '#6b7280',
                        primary: '#18181b',
                        accent: '#3b82f6'
                    }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', system-ui, sans-serif; }
    </style>
</head>
<body class="bg-surface text-primary antialiased min-h-screen">
    <header class="sticky top-0 z-10 bg-white/95 backdrop-blur border-b border-border">
        <div class="max-w-3xl mx-auto px-4 py-3 flex flex-wrap items-center justify-between gap-3">
            <a asp-controller="Home" asp-action="Index" class="text-xl font-semibold tracking-tight text-primary hover:opacity-80">Forum</a>
            <form asp-controller="Home" asp-action="Index" method="get" class="flex-1 min-w-[200px] max-w-md">
                <input type="search" name="search" value="@ViewBag.Search" placeholder="Search topics…" class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-sm placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent" />
            </form>
            <nav class="flex items-center gap-4">
                @if (ViewBag.Username != null)
                {
                    <span class="text-sm text-muted">@ViewBag.Username</span>
                    <a asp-controller="Posts" asp-action="Create" class="text-sm font-medium text-accent hover:underline">New post</a>
                    <form asp-controller="Home" asp-action="Logout" method="post" class="inline">
                        <button type="submit" class="text-sm text-muted hover:text-primary">Log out</button>
                    </form>
                }
                else
                {
                    <form asp-controller="Home" asp-action="SetUsername" method="post" class="flex gap-2">
                        <input type="text" name="username" placeholder="Choose username" maxlength="50" required class="rounded-lg border border-border bg-surface px-3 py-2 text-sm w-40 focus:outline-none focus:ring-2 focus:ring-accent/30" />
                        <button type="submit" class="rounded-lg bg-primary text-white px-3 py-2 text-sm font-medium hover:opacity-90">Join</button>
                    </form>
                }
            </nav>
        </div>
    </header>
    <main class="max-w-3xl mx-auto px-4 py-6">
        @RenderBody()
    </main>
    <footer class="max-w-3xl mx-auto px-4 py-4 mt-8 border-t border-border text-sm text-muted">
        &copy; @DateTime.UtcNow.Year Forum — <a asp-controller="Home" asp-action="Privacy" class="hover:text-primary">Privacy</a>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

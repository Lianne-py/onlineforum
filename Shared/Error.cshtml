@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="rounded-xl border border-red-200 bg-red-50 p-6 text-primary">
    <h1 class="text-xl font-semibold text-red-700">Error</h1>
    <p class="mt-2 text-muted">An error occurred while processing your request.</p>
    @if (Model.ShowRequestId)
    {
        <p class="mt-2 text-sm"><strong>Request ID:</strong> <code class="bg-white px-1 rounded">@Model.RequestId</code></p>
    }
</div>

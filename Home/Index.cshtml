@model List<ForumApp.Models.PostListItemViewModel>
@{
    ViewData["Title"] = "Home";
}

<div class="space-y-6">
    <h1 class="text-2xl font-semibold text-primary">Topics</h1>
    @if (ViewBag.Search != null)
    {
        <p class="text-muted text-sm">Results for “@ViewBag.Search”</p>
    }
    @if (Model.Count == 0)
    {
        <div class="rounded-xl border border-border bg-white p-8 text-center text-muted">
            <p>No posts yet.</p>
            @if (ViewBag.UserId != null)
            {
                <a asp-controller="Posts" asp-action="Create" class="mt-3 inline-block text-accent font-medium hover:underline">Create the first topic</a>
            }
            else
            {
                <p class="mt-2 text-sm">Choose a username above to post.</p>
            }
        </div>
    }
    else
    {
        <ul class="space-y-3">
            @foreach (var post in Model)
            {
                <li>
                    <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.Id" class="block rounded-xl border border-border bg-white p-4 hover:border-muted/50 transition-colors">
                        <div class="flex justify-between items-start gap-3">
                            <div class="min-w-0 flex-1">
                                <h2 class="font-medium text-primary truncate">@post.Title</h2>
                                <p class="text-sm text-muted mt-1 line-clamp-2">@post.ContentPreview</p>
                                <div class="flex flex-wrap items-center gap-3 mt-3 text-xs text-muted">
                                    <span>@post.Username</span>
                                    <span>@post.CreatedAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</span>
                                    <span>♥ @post.LikesCount</span>
                                    <span>↻ @post.RepostsCount</span>
                                    <span>💬 @post.CommentsCount</span>
                                </div>
                            </div>
                            @if (post.ImagePath != null || post.VideoPath != null)
                            {
                                <div class="shrink-0 w-16 h-16 rounded-lg overflow-hidden bg-surface">
                                    @if (post.ImagePath != null)
                                    {
                                        <img src="@post.ImagePath" alt="" class="w-full h-full object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center text-muted text-2xl">▶</div>
                                    }
                                </div>
                            }
                        </div>
                    </a>
                </li>
            }
        </ul>
    }
</div>

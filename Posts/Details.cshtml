@model ForumApp.Models.PostDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<article class="rounded-xl border border-border bg-white overflow-hidden">
    <div class="p-5 sm:p-6">
        <h1 class="text-xl font-semibold text-primary">@Model.Title</h1>
        <div class="flex flex-wrap items-center gap-3 mt-2 text-sm text-muted">
            <span>@Model.Username</span>
            <span>@Model.CreatedAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</span>
        </div>
        <div class="mt-4 text-primary whitespace-pre-wrap">@Model.Content</div>
        @if (Model.ImagePath != null)
        {
            <div class="mt-4">
                <img src="@Model.ImagePath" alt="Post attachment" class="max-w-full rounded-lg border border-border max-h-96 object-contain" />
            </div>
        }
        @if (Model.VideoPath != null)
        {
            <div class="mt-4">
                <video src="@Model.VideoPath" controls class="max-w-full rounded-lg border border-border">Your browser does not support video.</video>
            </div>
        }
        <div class="flex flex-wrap items-center gap-4 mt-6 pt-4 border-t border-border">
            <form asp-action="Like" asp-route-id="@Model.Id" method="post" class="inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="flex items-center gap-1.5 text-sm @(Model.CurrentUserLiked ? "text-accent font-medium" : "text-muted hover:text-primary")">
                    ♥ Like @(Model.LikesCount > 0 ? $"({Model.LikesCount})" : "")
                </button>
            </form>
            <form asp-action="Repost" asp-route-id="@Model.Id" method="post" class="inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="flex items-center gap-1.5 text-sm @(Model.CurrentUserReposted ? "text-accent font-medium" : "text-muted hover:text-primary")">
                    ↻ Repost @(Model.RepostsCount > 0 ? $"({Model.RepostsCount})" : "")
                </button>
            </form>
            <a asp-controller="Home" asp-action="Index" class="text-sm text-muted hover:text-primary">← Back to topics</a>
        </div>
    </div>
</article>

@if (ViewBag.UserId != null)
{
    <div class="mt-6 rounded-xl border border-border bg-white p-5">
        <h2 class="text-sm font-medium text-primary mb-3">Add a comment</h2>
        <form asp-action="AddComment" asp-route-postId="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <textarea name="Content" rows="3" required placeholder="Write your comment…" class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-primary focus:outline-none focus:ring-2 focus:ring-accent/30 resize-y"></textarea>
            <button type="submit" class="mt-2 rounded-lg bg-primary text-white px-4 py-2 text-sm font-medium hover:opacity-90">Comment</button>
        </form>
    </div>
}

<div class="mt-6">
    <h2 class="text-lg font-semibold text-primary mb-3">Comments (@Model.Comments.Count)</h2>
    @if (Model.Comments.Count == 0)
    {
        <p class="text-muted text-sm">No comments yet.</p>
    }
    else
    {
        <ul class="space-y-4">
            @foreach (var c in Model.Comments)
            {
                <li class="rounded-xl border border-border bg-white p-4">
                    <div class="flex justify-between items-start gap-3">
                        <div class="min-w-0 flex-1">
                            <div class="flex flex-wrap items-center gap-2 text-sm text-muted">
                                <span class="font-medium text-primary">@c.Username</span>
                                <span>@c.CreatedAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</span>
                            </div>
                            <p class="mt-1 text-primary whitespace-pre-wrap">@c.Content</p>
                        </div>
                        @if (ViewBag.UserId != null)
                        {
                            <form asp-action="LikeComment" asp-route-postId="@Model.Id" asp-route-commentId="@c.Id" method="post" class="shrink-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-sm @(c.CurrentUserLiked ? "text-accent font-medium" : "text-muted hover:text-primary")">♥ @(c.LikesCount > 0 ? c.LikesCount.ToString() : "")</button>
                            </form>
                        }
                    </div>
                </li>
            }
        </ul>
    }
</div>
